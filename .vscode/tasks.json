{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build VINAN",
      "type": "process",
      "command": "${env:HOME}/.dotnet/dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/Vinan.Api/Vinan.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
